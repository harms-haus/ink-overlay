{
	"name": "@harms-haus/ink-overlay",
	"version": "0.1.0",
	"description": "Overlay/modal/popover/toast/command-palette framework for Ink",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"demo": "tsx --tsconfig tsconfig.demo.json demo/app.tsx",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.demo.json",
		"lint": "xo",
		"format": "prettier --write .",
		"prepublishOnly": "npm run build"
	},
	"peerDependencies": {
		"ink": ">=7.0.0",
		"react": ">=19.0.0",
		"@types/react": ">=19.0.0"
	},
	"peerDependenciesMeta": {
		"@types/react": {
			"optional": true
		}
	},
	"dependencies": {
		"chalk": "^5.0.0",
		"match-sorter": "^6.3.4"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^7.0.0",
		"@types/node": "^22.0.0",
		"@types/react": "^19.2.0",
		"@vdemedes/prettier-config": "^2.0.1",
		"ink": "^7.1.0",
		"ink-testing-library": "^4.0.0",
		"prettier": "^3.4.0",
		"react": "^19.2.0",
		"tsx": "4.0.0",
		"typescript": "^5.8.0",
		"vitest": "^3.0.0",
		"xo": "^0.60.0"
	},
	"prettier": "@vdemedes/prettier-config",
	"xo": {
		"rules": {
			"import-x/extensions": "off",
			"@typescript-eslint/naming-convention": "off",
			"unicorn/prevent-abbreviations": "off",
			"@typescript-eslint/no-empty-function": "off",
			"react-hooks/exhaustive-deps": "off",
			"n/prefer-global/process": "off",
			"unicorn/prefer-event-target": "off",
			"@typescript-eslint/no-unsafe-assignment": "off",
			"@typescript-eslint/no-unsafe-argument": "off",
			"@typescript-eslint/no-unsafe-call": "off",
			"@typescript-eslint/no-unsafe-return": "off",
			"@typescript-eslint/class-literal-property-style": "off",
			"@typescript-eslint/switch-exhaustiveness-check": "off",
			"@typescript-eslint/member-ordering": "off",
			"@typescript-eslint/consistent-type-imports": "off",
			"@typescript-eslint/no-inferrable-types": "off",
			"no-mixed-operators": "off",
			"@typescript-eslint/prefer-nullish-coalescing": "off",
			"no-await-in-loop": "off",
			"import/order": "off",
			"import/no-duplicates": "off",
			"@typescript-eslint/ban-types": "off"
		},
		"ignores": [".spir-scout/**", "dist/**"]
	}
}
