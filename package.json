{
	"name": "@harms-haus/ink-overlay",
	"version": "0.1.0",
	"description": "Overlay/modal/popover/toast/command-palette framework for Ink",
	"license": "MIT",
	"author": "harms-haus",
	"homepage": "https://github.com/harms-haus/ink-overlay#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/harms-haus/ink-overlay.git"
	},
	"bugs": {
		"url": "https://github.com/harms-haus/ink-overlay/issues"
	},
	"keywords": [
		"ink",
		"react",
		"terminal",
		"console",
		"cli",
		"overlay",
		"modal",
		"popover",
		"tooltip",
		"toast",
		"command-palette",
		"tui"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"demo": "tsx --tsconfig tsconfig.demo.json demo/app.tsx",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.demo.json",
		"lint": "oxlint",
		"format": "prettier --write .",
		"prepublishOnly": "npm run build"
	},
	"peerDependencies": {
		"@types/react": ">=19.0.0",
		"ink": ">=7.0.0",
		"react": ">=19.0.0"
	},
	"peerDependenciesMeta": {
		"@types/react": {
			"optional": true
		}
	},
	"dependencies": {
		"chalk": "^5.0.0",
		"match-sorter": "^6.3.4"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^7.0.0",
		"@types/node": "^22.0.0",
		"@types/react": "^19.2.0",
		"@vdemedes/prettier-config": "^2.0.1",
		"ink": "^7.1.0",
		"ink-testing-library": "^4.0.0",
		"oxlint": "^1.72.0",
		"prettier": "^3.4.0",
		"react": "^19.2.0",
		"tsx": "4.0.0",
		"typescript": "^5.8.0",
		"vitest": "^3.0.0"
	},
	"prettier": "@vdemedes/prettier-config"
}
